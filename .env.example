# Nock Wallet — environment (all optional)

# NOCK/USD price feed (CoinGecko-style JSON). Empty = price display hidden.
# Example: https://api.coingecko.com/api/v3/simple/price?ids=nockchain&vs_currencies=usd
VITE_PRICE_URL='https://api.coingecko.com/api/v3/simple/price?ids=nockchain&vs_currencies=usd'

# Atomic swap (NOCK ↔ USDC on Base)
VITE_KV_URL=https://api.atomicnock.com
VITE_HTLC_ADDRESS=0x5ac37e7A63b107d226d0b88129B8EB8b07172B75
VITE_CHAIN_ID=8453
VITE_PRICE_URL='https://api.coingecko.com/api/v3/simple/price?ids=nockchain&vs_currencies=usd'

# WalletConnect (Reown) — lets the installed PWA connect to mobile wallets
# (Phantom, MetaMask, …) via deep-link/QR. Free project id from
# https://cloud.reown.com. Empty = WalletConnect option hidden; only injected
# (in-app-browser / desktop-extension) wallets are offered.
VITE_WALLETCONNECT_PROJECT_ID=56b8c5a9471e0860a63a1a60eda24ef0
